# Profiling run — prints TimerOutput breakdown at the end
set Final time    = 1.0
set Wave speed    = 1.0
set Refinements   = 6
set FE degree     = 1
set Scheme        = CN
set Theta         = 0.5
set Time step     = 0.005
set Output every  = 0
set Output dir    = ../results
set MMS           = false
set Profiling     = true
