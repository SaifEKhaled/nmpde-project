# RK4: 4th-order, explicit
# CFL at ref=5: dt_cfl ~ 0.022; use dt=0.005 (CFL=0.23, safe)
set Final time    = 1.0
set Wave speed    = 1.0
set Refinements   = 5
set FE degree     = 1
set Scheme        = RK4
set Theta         = 0.5
set Time step     = 0.005
set Output every  = 10
set Output dir    = ../results
